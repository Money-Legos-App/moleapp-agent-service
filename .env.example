# Alkebulan Agent Service Environment Variables

# Service Configuration
NODE_ENV=development
DEBUG=false

# Database (shared with other services)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wallet_backend_unified

# Wallet Service Bridge
WALLET_SERVICE_URL=http://localhost:3002
WALLET_SERVICE_API_KEY=agent_internal_key_2025

# User Service
USER_SERVICE_URL=http://localhost:3001

# DeepSeek LLM
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Hyperliquid
# For testnet: HYPERLIQUID_MAINNET=false (uses api.hyperliquid-testnet.xyz)
# For production: HYPERLIQUID_MAINNET=true (uses api.hyperliquid.xyz)
HYPERLIQUID_API_URL=https://api.hyperliquid-testnet.xyz
HYPERLIQUID_MAINNET=false
MOLEAPP_AGENT_ADDRESS=0x_your_agent_wallet_address_here

# DRY RUN Mode (Paper Trading)
# Set to false for live trading on Hyperliquid (production)
DRY_RUN=true

# HL Treasury (TESTNET ONLY - auto-funds users via usdSend)
# Do NOT set these in production — users deposit via Arbitrum bridge
HL_TREASURY_PRIVATE_KEY=
HL_TREASURY_ADDRESS=

# Redis
REDIS_URL=redis://redis-cache:6379
# For Upstash (production): REDIS_URL=rediss://default:xxx@host:6379

# Keycloak (service-to-service auth)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=moleapp
KEYCLOAK_CLIENT_ID=agent-service
KEYCLOAK_CLIENT_SECRET=

# FAISS Vector Store
FAISS_INDEX_PATH=/app/data/faiss_index
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Scheduler
ANALYSIS_INTERVAL_MINUTES=15
PNL_SYNC_INTERVAL_SECONDS=60
PNL_SNAPSHOT_HOUR=0

# Trading Constraints
ALLOWED_ASSETS=ETH-USD,BTC-USD
MAX_LEVERAGE_CONSERVATIVE=1
MAX_LEVERAGE_MODERATE=2
MAX_LEVERAGE_AGGRESSIVE=3

# Mission Defaults
DEFAULT_MISSION_DURATION_DAYS=30
MIN_DEPOSIT_USDC=10
MAX_DEPOSIT_USDC=10000

# Logging
LOG_LEVEL=INFO

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
